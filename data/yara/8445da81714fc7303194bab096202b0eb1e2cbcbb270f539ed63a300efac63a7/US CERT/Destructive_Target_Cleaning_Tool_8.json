            "rule_text": "rule Destructive_Target_Cleaning_Tool_8\n{\n\tmeta:\n\t\tauthor = \"US CERT\"\n\t\treference = \"https://www.us-cert.gov/ncas/alerts/TA14-353A\"\n\n\tstrings:\n\t\t$license = \"{}\"\n\t\t$PuTTY = \"{50007500540054005900}\"\n\n\tcondition:\n\t\t( uint16( 0 ) == 0x5A4D and uint16( uint32( 0x3c ) ) == 0x4550 ) and $license and not $PuTTY\n}\n",
            "vulnerabilities": []
        }
    ]
