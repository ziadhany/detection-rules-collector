            "rule_text": "rule PlugX : Family\n{\n\tmeta:\n\t\tdescription = \"PlugX\"\n\t\tauthor = \"Seth Hardy\"\n\t\tlast_modified = \"2014-06-12\"\n\n\tcondition:\n\t\tPlugXBootLDRCode or PlugXStrings\n}\n",
            "vulnerabilities": []
