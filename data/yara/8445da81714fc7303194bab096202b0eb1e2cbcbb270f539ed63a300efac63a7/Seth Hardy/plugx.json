        },
        {
            "rule_metadata": {
                "name": "PlugXStrings",
                "tags": [
                    "PlugX",
                    "Family"
                ],
                "description": "PlugX Identifying Strings",
                "author": "Seth Hardy",
                "last_modified": "2014-06-12"
            },
            "rule_text": "private rule PlugXStrings : PlugX Family\n{\n\tmeta:\n\t\tdescription = \"PlugX Identifying Strings\"\n\t\tauthor = \"Seth Hardy\"\n\t\tlast_modified = \"2014-06-12\"\n\n\tstrings:\n\t\t$BootLDR = \"boot.ldr\" wide ascii\n\t\t$Dwork = \"d:\\\\work\" nocase\n\t\t$Plug25 = \"plug2.5\"\n\t\t$Plug30 = \"Plug3.0\"\n\t\t$Shell6 = \"Shell6\"\n\n\tcondition:\n\t\t$BootLDR or ( $Dwork and ( $Plug25 or $Plug30 or $Shell6 ) )\n}\n",
            "vulnerabilities": []
        },
        {
            "rule_metadata": {
                "name": "PlugX",
                "tags": [
