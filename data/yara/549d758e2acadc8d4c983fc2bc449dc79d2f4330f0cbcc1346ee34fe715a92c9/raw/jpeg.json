{
    "source_url": "https://github.com/Xumeiquer/yara-forensics/blob/master/raw/jpeg.yar",
    "rules": [
        {
            "rule_metadata": {
                "name": "jpeg",
                "tags": [
                    "JFIF",
                    "JPE",
                    "JPEG",
                    "JPG"
                ],
                "author": "Jaume Martin"
            },
            "rule_text": "rule jpeg : JFIF JPE JPEG JPG\n{\n\tmeta:\n\t\tauthor = \"Jaume Martin\"\n\n\tstrings:\n\t\t$a = {FF D8 FF E0 ?? ?? 4A 46 49 46 00}\n\n\tcondition:\n\t\t$a\n}\n",
            "vulnerabilities": []
        },
        {
