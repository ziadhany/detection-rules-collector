                ],
                "author": "Jaume Martin"
            },
            "rule_text": "rule jpg_with_EXIF : JPG\n{\n\tmeta:\n\t\tauthor = \"Jaume Martin\"\n\n\tstrings:\n\t\t$a = {FF D8 FF E1 ?? ?? 45 78 69 66 00}\n\n\tcondition:\n\t\t$a\n}\n",
            "vulnerabilities": []
        },
